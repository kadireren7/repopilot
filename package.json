{
  "name": "repopilot",
  "version": "0.1.0",
  "description": "CLI tool to analyze repository ship-readiness and generate missing DevOps essentials.",
  "main": "dist/index.js",
  "bin": {
    "repopilot": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE", ".env.example"],
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "test": "jest --config jest.config.cjs",
    "analyze": "ts-node src/index.ts analyze",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "github",
    "devops",
    "cli",
    "automation",
    "ship-readiness",
    "infrastructure"
  ],
  "author": "RepoPilot Team",
  "license": "MIT",
  "devDependencies": {
    "@types/chalk": "^0.4.31",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "fs-extra": "^11.3.4",
    "octokit": "^5.0.5",
    "yargs": "^18.0.0"
  }
}
